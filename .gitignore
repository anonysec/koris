# ═══════════════════════════════════════════════════
# Koris .gitignore — comprehensive
# ═══════════════════════════════════════════════════

# ── Compiled binaries ──
/panel
/koris
/koris-full-*
/koris-lite-*
/panel-binary
/node-binary
*.exe

# ── Go build artifacts ──
dist/
*.test
*.out
coverage.html

# ── Dependencies ──
node_modules/
vendor/

# ── Frontend build artifacts ──
# Keep directories (for go:embed) via .gitkeep, ignore everything else
web/*/www/*
!web/*/www/.gitkeep
web/*/dist/
package-lock.json

# ── Secrets & credentials ──
*.pem
*.key
*.crt
.env
.env.*
!.env.example
!deploy/.env.example
deploy/.env
deploy/panel.env
docker/panel.env

# ── Runtime files ──
*.log
*.pid
*.sock
*.tmp
*.bak
*.bak-*

# ── OS files ──
.DS_Store
Thumbs.db

# ── IDE / editor ──
.idea/
.vscode/
*.swp
*.swo
*~

# ── Stray backup dirs ──
web/_shared.bak*

# ── Generated docs site (GitHub Pages) ──
_site/

# buf regen artifact (symlink created under knodepb during proto gen)
internal/knodepb/knode
