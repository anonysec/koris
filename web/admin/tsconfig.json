{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@koris/core":         ["../core/index.ts"],
      "@koris/core/*":       ["../core/*"],
      "@koris/theme":        ["../theme/index.ts"],
      "@koris/theme/*":      ["../theme/*"],
      "@koris/ui/*":         ["../theme/components/*"],
      "@koris/ui":           ["../theme/components"],
      "@koris/composables/*": ["../core/composables/*"],
      "@koris/composables":  ["../core/composables"],
      "@koris/types/*":      ["../core/types/*"],
      "@koris/types":        ["../core/types"],
      "@koris/styles/*":     ["../core/styles/*"],
      "@koris/styles":       ["../core/styles"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue", "../core/**/*.ts", "../core/**/*.vue", "../theme/**/*.ts", "../theme/**/*.vue"],
  "references": []
}
