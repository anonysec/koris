# KorisPanel deployment environment — TEMPLATE (everything commented by default).
#
# Copy to `.env` and uncomment + edit only the values you need to change:
#   cp .env.example .env && chmod 600 .env
#
# Compose auto-loads `.env` from this directory for ${VAR} substitution and
# injects the same vars into the panel container. NEVER commit your real `.env`.
# Every option below shows its effective default after the `#`.
#
# HTTPS is OPTIONAL and installed post-deploy. The default install serves plain
# HTTP on 127.0.0.1 only (loopback, not public) so an admin can reach the panel
# locally to install a certificate. Run `koris cert ...` to expose HTTPS.

# ─── PostgreSQL (TimescaleDB) ──────────────────────────────────────────
# POSTGRES_DB=koris
# POSTGRES_USER=koris
# POSTGRES_PASSWORD=            # REQUIRED — generate: openssl rand -base64 18
# POSTGRES_PORT=5432           # host port mapped to the container's 5432

# ─── Panel server ─────────────────────────────────────────────────────
# PANEL_SESSION_SECRET=         # REQUIRED — generate: openssl rand -base64 32
# PANEL_SETUP_KEY=              # one-time first-run wizard key: openssl rand -hex 8
# PANEL_RADIUS_SECRET=          # optional RADIUS shared secret: openssl rand -hex 16
# PANEL_DOMAIN=localhost
# PANEL_DEV_MODE=false
# Runtime routing prefixes — must match the Dockerfile Vite base paths.
# PANEL_ADMIN_PATH=/admin/
# PANEL_PORTAL_PATH=/account/
# Single HTTPS port — the panel never binds 80/443. Blank in prompts => 2096.
# PANEL_PORT=2096
# KORIS_ADMIN_BASE=/admin/     # build-time only; usually == PANEL_ADMIN_PATH
# KORIS_PORTAL_BASE=/account/  # build-time only; usually == PANEL_PORTAL_PATH

# ─── TLS (default install = HTTP on 127.0.0.1, loopback only) ─────────────
# The default install serves plaintext HTTP bound to 127.0.0.1 only (local
# access, not public). Install a cert to expose HTTPS with the `koris` binary:
#   koris cert selfsign            # auto-generated self-signed (DEV; browser warns)
#   koris cert letsencrypt --domain=example.com   # Let's Encrypt (ACME)
#   koris cert path --cert=... --key=...          # your own cert/key
# These write KORIS_HOME/.env (/etc/koris/.env) and apply on the next restart.
# PANEL_TLS_ENABLED=false
# Mode: disabled (default HTTP/loopback) | selfsigned | manual | acme
# PANEL_TLS_MODE=disabled
# Cert paths are the IN-CONTAINER mount point (/etc/koris == host KORIS_HOME).
# PANEL_TLS_CERT=/etc/koris/certs/cert.pem
# PANEL_TLS_KEY=/etc/koris/certs/key.pem
# PANEL_TLS_CERT_DIR=/etc/koris/certs
# Optional subdomain routing (leave empty to use path prefixes).
# PANEL_ADMIN_HOST=admin.example.com
# PANEL_PORTAL_HOST=account.example.com

# ─── Optional: shared Redis ───────────────────────────────────────────
# Set to redis:6379 to enable the shared job queue / cache / rate limiter.
# Leave empty and each service uses its in-memory fallback.
# REDIS_ADDR=
# REDIS_PORT=6379

# ─── Optional: pgAdmin (enable with: docker compose --profile pgadmin up -d) ──
# PGADMIN_EMAIL=admin@koris.local
# PGADMIN_PASSWORD=             # generate: openssl rand -base64 16
# PGADMIN_PORT=5050

# ─── knode agent ──────────────────────────────────────────────────────
# Comma-separated API keys the panel uses to manage this node. Leave empty to
# have the container generate a secure random key on first boot (printed to
# logs — read it with: docker compose exec knode cat /etc/knode/config.toml).
# KNODE_API_KEYS=
# KNODE_RADIUS_SECRET=
# KNODE_LISTEN_ADDR=:2083
# KNODE_PORT=2083
# KNODE_INSECURE_ALLOW_NO_AUTH=false
# KNODE_ENABLE_REST=false
# KNODE_LOG_LEVEL=info

# ─── Optional: image overrides ───────────────────────────────────────
# Leave unset to build from source; set to a published image to pull instead.
# KORIS_IMAGE=koris/koris:1.0.0
# KNODE_IMAGE=koris/knode:1.0.0

# ─── Optional: build flags ───────────────────────────────────────────
# e.g. "lite" for the Lite edition.
# BUILD_TAGS=
