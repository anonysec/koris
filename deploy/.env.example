# Koris Deployment Environment Variables
# Copy to .env and fill in your values: cp .env.example .env && chmod 600 .env

# ─── PostgreSQL ───
POSTGRES_DB=koris
POSTGRES_USER=koris
POSTGRES_PASSWORD=<generate: openssl rand -base64 18>

# ─── Panel ───
PANEL_SESSION_SECRET=<generate: openssl rand -base64 32>
PANEL_SETUP_KEY=<generate: openssl rand -hex 8>
PANEL_DOMAIN=panel.example.com
PANEL_DEV_MODE=false
PANEL_ADMIN_PATH=/admin/
PANEL_PORTAL_PATH=/account/
# PANEL_ADMIN_HOST=admin.example.com
# PANEL_PORTAL_HOST=account.example.com

# ─── pgAdmin ───
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=<generate: openssl rand -base64 16>
