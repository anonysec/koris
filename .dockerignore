# Version control
.git
.gitignore

# Local environment / secrets — never bake these into the image.
.env
docker/panel.env
*.pem

# Dependencies are reinstalled inside the builder; exclude them from the
# build context to keep it small and force a clean, reproducible install.
**/node_modules
web/node_modules

# NOTE: do NOT exclude web/*/www here. The release image
# (Dockerfile.release) embeds the pre-built SPAs straight from the build
# context — they are produced by the `frontend` job and downloaded into
# web/ before `docker build`. The main Dockerfile rebuilds the SPAs itself,
# so it does not depend on these being present in the context.

# Editor / OS noise
.vscode
.idea
*.swp
.DS_Store
Thumbs.db
.kiro
