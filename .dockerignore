# Version control
.git
.gitignore

# Local environment / secrets — never bake these into the image.
.env
docker/panel.env
*.pem

# Dependencies are reinstalled inside the builder; exclude them from the
# build context to keep it small and force a clean, reproducible install.
**/node_modules
web/node_modules

# Pre-built SPAs are regenerated from source during the build. Excluding the
# stale www/ dirs guarantees the embed step picks up freshly built assets.
web/admin/www
web/portal/www
web/landing/www

# Editor / OS noise
.vscode
.idea
*.swp
.DS_Store
Thumbs.db
.kiro
