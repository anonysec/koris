# KorisPanel Docker Environment Configuration
# Copy this to panel.env and fill in your values

# ─── Database ─────────────────────────────────────────────────────────
# Full MySQL/MariaDB DSN (required in production)
PANEL_DB_DSN=koris:CHANGE_ME@tcp(db:3306)/koris?parseTime=true&multiStatements=true&charset=utf8mb4,utf8

# MariaDB container credentials (must match DSN above)
DB_ROOT_PASS=change-me-root-password
DB_PASS=CHANGE_ME

# ─── Panel Server ────────────────────────────────────────────────────
PANEL_ADDR=0.0.0.0:2026
PANEL_SESSION_SECRET=change-me-to-a-random-64-char-string-at-least-32-characters-long
PANEL_SETUP_KEY=change-me-setup-key
PANEL_MIGRATIONS=/app/migrations
PANEL_TUI_ENABLED=false

# ─── Optional ────────────────────────────────────────────────────────
# PANEL_DOMAIN=panel.example.com
# PANEL_WORKERS=2
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
