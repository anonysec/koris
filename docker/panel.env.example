# KorisPanel Docker Configuration (EXAMPLE)
# Copy to docker/panel.env and fill in real values for local deployment.
#
# SECURITY:
#   - Never commit a file containing real secrets.
#   - POSTGRES_PASSWORD and PANEL_SESSION_SECRET must be high-entropy random values.
#   - PANEL_SETUP_KEY gates first-boot owner creation; always set it in production.
#   - pgAdmin (if deployed) requires its own PGADMIN_PASSWORD - never use defaults.
#   - The dev compose (docker-compose.yml) reads secrets from the environment;
#     provide them via `export` or a secrets manager, not a committed file.

# Database (TimescaleDB/PostgreSQL)
PANEL_DB_BACKEND=timescaledb
PANEL_PG_DSN=postgres://koris:CHANGE_ME@db:5432/koris?sslmode=disable
POSTGRES_DB=koris
POSTGRES_USER=koris
POSTGRES_PASSWORD=CHANGE_ME

# Panel Server
PANEL_ADDR=0.0.0.0:2026
PANEL_SESSION_SECRET=change-me-to-a-random-64-char-string-at-least-32
PANEL_SETUP_KEY=change-me-setup-key
PANEL_MIGRATIONS=/app/migrations
PANEL_TLS_MODE=selfsigned

# Optional
# PANEL_DOMAIN=panel.example.com
# PANEL_TLS_MODE=acme
# PANEL_WORKERS=2
# TELEGRAM_BOT_TOKEN=your-bot-token
