{
  "name": "@koris/core",
  "version": "1.0.0",
  "description": "Framework layer for Koris apps — composables, API client, types, base CSS. Never overridden by themes.",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./composables/*": "./composables/*",
    "./types": "./types/index.ts",
    "./types/*": "./types/*",
    "./styles/*": "./styles/*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "sortablejs": "^1.15.7",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "fast-check": "^4.8.0",
    "happy-dom": "^20.10.3",
    "vitest": "^3.2.6"
  }
}
