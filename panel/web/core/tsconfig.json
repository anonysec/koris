{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@koris/core":          ["./index.ts"],
      "@koris/core/*":        ["./*"],
      "@koris/composables":   ["./composables"],
      "@koris/composables/*": ["./composables/*"],
      "@koris/types":         ["./types"],
      "@koris/types/*":       ["./types/*"]
    }
  },
  "include": ["**/*.ts", "**/*.vue"]
}
